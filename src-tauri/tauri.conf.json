{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parchmint",
  "version": "0.1.1",
  "identifier": "com.mazher.parchmint",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Parchmint",
        "width": 1280,
        "height": 832,
        "minWidth": 800,
        "minHeight": 600,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Abu Mazher Uddin",
    "copyright": "© 2026 Abu Mazher Uddin",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Parchmint.md",
        "description": "Markdown document",
        "role": "Editor"
      }
    ]
  }
}
